# ─────────────────────────────────────────────────────────────────────────────
# OPENCLAW — Environment Variables
# Copia questo file in .env e compila con i tuoi valori reali.
# NON committare mai il file .env nel repository.
# ─────────────────────────────────────────────────────────────────────────────

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── HyperEVM ──────────────────────────────────────────────────────────────────
# Wallet dedicato per l'agente (NON il wallet principale)
OPENCLAW_PRIVATE_KEY=0xYOUR_AGENT_WALLET_PRIVATE_KEY

# Indirizzo del contratto OpenClawAgent deployato su HyperEVM
# Lascia vuoto finché non hai deployato il contratto
OPENCLAW_CONTRACT=0xYOUR_DEPLOYED_CONTRACT_ADDRESS

# RPC di HyperEVM (default pubblico)
HYPER_EVM_RPC=https://rpc.hyperliquid.xyz/evm

# ── Parametri trading ─────────────────────────────────────────────────────────
# true = simula senza inviare transazioni reali
DRY_RUN=true

# Soglia minima grade per eseguire il trade (A+, A, B+, B, C)
MIN_GRADE=B+

# Leva massima consentita (1-10)
MAX_LEVERAGE=5

# Modello Claude da usare
# claude-sonnet-4-6  (veloce, economico)
# claude-opus-4-6    (più profondo, più lento)
CLAUDE_MODEL=claude-sonnet-4-6
